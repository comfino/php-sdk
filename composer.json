{
    "name": "comfino/php-sdk",
    "description": "Comfino PHP SDK - backend routines for e-commerce platforms integration.",
    "license": "BSD-3-Clause",
    "type": "library",
    "keywords": [
        "comfino",
        "payment",
        "gateway",
        "sdk",
        "api",
        "client",
        "psr-3",
        "psr-6",
        "psr-7",
        "psr-17",
        "psr-18",
        "bnpl",
        "installments",
        "pay later",
        "woocommerce",
        "prestashop",
        "magento",
        "ecommerce"
    ],
    "homepage": "https://github.com/comfino/php-sdk",
    "readme": "README.md",
    "authors": [
        {
            "name": "Artur Kozubski",
            "email": "a.kozubski@artkosoft.pl",
            "homepage": "https://artkosoft.pl"
        }
    ],
    "support": {
        "issues": "https://github.com/comfino/php-sdk/issues",
        "source": "https://github.com/comfino/php-sdk",
        "docs": "https://github.com/comfino/php-sdk#readme"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "comfino/php-api-client": "*",
        "psr/cache": "^1.0 || ^2.0 || ^3.0",
        "psr/log": "^3.0",
        "symfony/cache-contracts": "^2.0 || ^3.0"
    },
    "require-dev": {
        "cache/array-adapter": "^1.1",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "sunrise/http-client-curl": "^2.2",
        "vimeo/psalm": "^5.0"
    },
    "suggest": {
        "cache/filesystem-adapter": "^1.2 - PSR-6 filesystem cache implementation (requires league/flysystem ^3.33).",
        "league/flysystem": "^3.33 - required by cache/filesystem-adapter ^1.2.",
        "monolog/monolog": "PSR-3 logger implementation.",
        "symfony/cache": "Recommended PSR-6 + tagging implementation (TagAwareAdapter)."
    },
    "autoload": {
        "psr-4": {
            "Comfino\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Comfino\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage",
        "cs": "vendor/bin/phpcs",
        "cs-fix": "vendor/bin/phpcbf",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/comfino/php-api-client-staging"
        }
    ],
    "minimum-stability": "beta",
    "prefer-stable": true
}

#!/bin/bash

if command -v docker-compose > /dev/null ; then
    for arg in "$@"; do
        if [[ "$arg" == --coverage* ]]; then
            docker-compose run --rm php-sdk-coverage php ./vendor/bin/phpunit "$@"
            exit $?
        fi
    done

    docker-compose exec php-sdk php ./vendor/bin/phpunit "$@"
else
    php ./vendor/bin/phpunit "$@"
fi

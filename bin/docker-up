#!/bin/sh

# Mode-aware Docker startup script
# Automatically detects dev/prod mode and uses appropriate docker-compose files.
# Dev mode: docker-compose.yml + docker-compose.dev.yml (with local volumes)
# Prod mode: docker-compose.yml only (no local volumes)

set -e

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_DIR=$(dirname "$SCRIPT_DIR")

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Detect current dependency mode.
get_current_mode() {
    if grep -q '"type": "path"' "$PROJECT_DIR/composer.json" 2>/dev/null; then
        echo "dev"
    else
        echo "prod"
    fi
}

MODE=$(get_current_mode)

if [ "$MODE" = "dev" ]; then
    printf "${BLUE}Starting containers in DEV mode (with local dependency volumes)${NC}\n"
    docker-compose -f "$PROJECT_DIR/docker-compose.yml" -f "$PROJECT_DIR/docker-compose.dev.yml" up "$@"
else
    printf "${BLUE}Starting containers in PROD mode (no local dependency volumes)${NC}\n"
    docker-compose -f "$PROJECT_DIR/docker-compose.yml" up "$@"
fi

printf "\n${GREEN}✓ Containers started in $(echo $MODE | tr '[:lower:]' '[:upper:]') mode${NC}\n"
